# ServiceNow
SNOW_INSTANCE_URL=https://your-instance.service-now.com/
SNOW_USERNAME=
SNOW_PASSWORD=
SNOW_EXPORT_FIELDS=sys_id,number,short_description,priority,urgency,impact,state,category,subcategory,opened_at,resolved_at,closed_at,location,cmdb_ci,assignment_group,sys_updated_on
SNOW_EXPORT_START_DATE=2024-01-01

# Grafana
GRAFANA_URL=https://grafana.ext.icrc.org
GRAFANA_API_TOKEN=
GRAFANA_PROMETHEUS_DS_ID=4

# NetBox
NETBOX_URL=https://netbox.test.icrc.org
NETBOX_TOKEN=

# OSINT APIs
ACLED_EMAIL=
ACLED_PASSWORD=
CF_API_TOKEN=
# IODA: no auth required

# Scheduler
HENRI_SCHEDULER_ENABLED=0           # Set to 1 to enable background scheduler
SCHEDULER_FULL_HOUR=6               # Hour (UTC) for daily full pipeline
SCHEDULER_FULL_MINUTE=0
SCHEDULER_OSINT_INTERVAL_MINUTES=15 # Quick OSINT check interval

# General
DATA_DIR=./data
